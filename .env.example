# ──────────────────────────────────────────────────────────────────────────
# Builder agent (used by docker-compose.builder.yml) — supply ONE (OAuth wins)
# ──────────────────────────────────────────────────────────────────────────
# Pro/Max subscription token, generated by `claude setup-token` (no API billing):
CLAUDE_CODE_OAUTH_TOKEN=
# OR an API key (per-token API billing):
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Application (consumed once Phase 1+ exists; validated by a Zod env schema at boot)
# The app boots without provider keys — capabilities degrade gracefully.
# ──────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
API_PORT=8080
LOG_LEVEL=info

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
DATABASE_URL=postgresql://rag:rag@postgres:5432/rag

# Redis / BullMQ
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_chunks

# LLM / embeddings (Vercel AI SDK) — set the providers you use
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
ANTHROPIC_API_KEY_APP=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

# Reranker
RERANK_PROVIDER=cohere
COHERE_API_KEY=

# RAG tuning
RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=20
RAG_RERANK_TOP_N=5

# Worker / queue hardening
WORKER_CONCURRENCY=5
BULLMQ_ATTEMPTS=3
BULLMQ_BACKOFF_MS=1000

# API hardening
API_BODY_LIMIT=5mb
RATE_LIMIT_MAX=0
RATE_LIMIT_WINDOW_MS=60000
API_KEY=

# Observability (optional — NoOp when unset)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
